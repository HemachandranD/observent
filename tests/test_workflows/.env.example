# Azure OpenAI - one set of vars, used by:
#   - the direct Azure call (langgraph answer node + building_blocks.direct_azure_chat)
#   - the shared LLM service (llm_service.py)
#   - CrewAI's agent LLM (mapped onto litellm's AZURE_API_* names in crewai_app.py)
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# Shared LLM service (started separately with uvicorn / python llm_service.py)
LLM_SERVICE_URL=http://localhost:8001
LLM_SERVICE_PORT=8001
