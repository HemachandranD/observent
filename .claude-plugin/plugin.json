{
  "name": "observent",
  "description": "Production-grade observability for multi-agent Python apps. Detects your framework (LangGraph, CrewAI, Microsoft Agent Framework, Anthropic Agents SDK, OpenAI Agents SDK, smolagents, LlamaIndex, or a Custom no-framework path) and wires up Arize Phoenix, Langfuse, SigNoz, Elastic APM, or LangSmith with correct span hierarchy, context propagation, and mandatory OTel/OpenInference attributes.",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "homepage": "https://github.com/HemachandranD/observent",
  "repository": "https://github.com/HemachandranD/observent",
  "keywords": [
    "observability",
    "opentelemetry",
    "openinference",
    "tracing",
    "llm",
    "agents",
    "multi-agent",
    "langgraph",
    "crewai",
    "phoenix",
    "langfuse",
    "signoz",
    "langsmith"
  ],
  "author": {
    "name": "Hemachandran Dhinakaran",
    "url": "https://github.com/HemachandranD"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/skills/observent/scripts/session_start_detect.py\"",
            "timeout": 15,
            "statusMessage": "observent: detecting frameworks & backends..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/skills/observent/scripts/prompt_nudge.py\"",
            "timeout": 5,
            "statusMessage": "observent: checking for observability intent..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/skills/observent/scripts/posttooluse_validate.py\"",
            "timeout": 10,
            "statusMessage": "observent: syntax-checking generated file..."
          }
        ]
      }
    ]
  }
}
